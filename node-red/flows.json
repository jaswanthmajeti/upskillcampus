    {
        "id": "6708a09f42b52f75",
        "type": "function",
        "z": "9f0a4d1acb454857",
        "name": "UI Payload Splitter",
        "func": "// Parse the incoming string payload if it isn't already an object\nconst data = (typeof msg.payload === \"string\") ? JSON.parse(msg.payload) : msg.payload;\n\n// Create 6 independent message objects targeting our 6 outputs with topics added!\nconst outTemp      = { payload: data.temperature, topic: \"Temperature\" };\nconst outHumidity  = { payload: data.humidity, topic: \"Humidity\" };\nconst outVoltage   = { payload: data.voltage, topic: \"Voltage\" };\nconst outCurrent   = { payload: data.current, topic: \"Current\" };\nconst outEnergy    = { payload: data.energy, timestamp: Date.now(), topic: \"Energy\" };\nconst outOccupancy = { payload: data.occupancy, topic: \"Occupancy\" };\n\n// Return the array matching the physical output ports (1 to 6)\nreturn [outTemp, outHumidity, outVoltage, outCurrent, outEnergy, outOccupancy];",
        "outputs": 6,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
